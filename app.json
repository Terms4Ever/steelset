{
  "expo": {
    "name": "Liftbook",
    "slug": "setly",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/liftbook-icon.png",
    "scheme": "setly",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0A0B0D",
    "ios": {
      "bundleIdentifier": "cz.setly.app",
      "buildNumber": "1",
      "supportsTablet": false,
      "usesAppleSignIn": true,
      "icon": {
        "light": "./assets/images/liftbook-icon.png",
        "dark": "./assets/images/liftbook-icon-dark.png",
        "tinted": "./assets/images/liftbook-icon-tinted.png"
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "cz.setly.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#00E07A",
        "foregroundImage": "./assets/images/liftbook-glyph-dark.png",
        "monochromeImage": "./assets/images/liftbook-icon-tinted.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0A0B0D",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 120,
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-sharing",
      "expo-apple-authentication",
      ["react-native-cloud-storage", { "iCloudContainerEnvironment": "Production" }]
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "de37acc9-cc92-4d28-8e35-4d8998fd26f9"
      }
    },
    "owner": "terms4e"
  }
}
